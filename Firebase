    <!-- Firebase (cloud sync + Google login) -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import { getAuth, GoogleAuthProvider, signInWithPopup, signInWithRedirect, getRedirectResult, onAuthStateChanged, signOut, createUserWithEmailAndPassword, signInWithEmailAndPassword, sendPasswordResetEmail } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
        import { getFirestore, doc, getDoc, setDoc, collection, query, where, getDocs, enableIndexedDbPersistence } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAFGVmWtp7TL1ivJbfID6D4Y7OovXTiw2k",
            authDomain: "corepoker-83a05.firebaseapp.com",
            projectId: "corepoker-83a05",
            storageBucket: "corepoker-83a05.firebasestorage.app",
            messagingSenderId: "534050018162",
            appId: "1:534050018162:web:70d8c985f10f02b18e43eb"
        };

        const fbApp = initializeApp(firebaseConfig);
        const auth = getAuth(fbApp);
        const db = getFirestore(fbApp);
        try { await enableIndexedDbPersistence(db); } catch(e) { /* multi-tab or unsupported */ }

        const provider = new GoogleAuthProvider();

        // Expose a small, stable API for the main app to call
        window.fb = {
            ready: false,
            user: null,
            signIn() {
                // Popup first; fall back to redirect for in-app webviews that block popups
                return signInWithPopup(auth, provider).catch((err) => {
                    if (err && (err.code === 'auth/popup-blocked' || err.code === 'auth/operation-not-supported-in-this-environment' || err.code === 'auth/cancelled-popup-request')) {
                        return signInWithRedirect(auth, provider);
                    }
                    throw err;
                });
            },
            signUpEmail(email, password) {
                return createUserWithEmailAndPassword(auth, email, password);
            },
            signInEmail(email, password) {
                return signInWithEmailAndPassword(auth, email, password);
            },
            resetPassword(email) {
                return sendPasswordResetEmail(auth, email);
            },
            signOut() { return signOut(auth); },
            // Save this user's whole dataset under their uid
            async saveUserData(uid, data) {
                await setDoc(doc(db, 'users', uid), { data: JSON.stringify(data), updatedAt: Date.now() });
            },
            async loadUserData(uid) {
                const snap = await getDoc(doc(db, 'users', uid));
                if (snap.exists()) {
                    try { return JSON.parse(snap.data().data); } catch(e) { return null; }
                }
                return null;
            },
            // Publish a group (with its games) under a share code so others can pull it
            async publishGroup(code, payload) {
                await setDoc(doc(db, 'sharedGroups', code), { payload: JSON.stringify(payload), updatedAt: Date.now() });
            },
            async fetchGroupByCode(code) {
                const snap = await getDoc(doc(db, 'sharedGroups', code));
                if (snap.exists()) {
                    try { return JSON.parse(snap.data().payload); } catch(e) { return null; }
                }
                return null;
            }
        };

        // Handle redirect sign-in result (for webviews)
        getRedirectResult(auth).catch(() => {});

        onAuthStateChanged(auth, (user) => {
            window.fb.ready = true;
            window.fb.user = user ? { uid: user.uid, name: user.displayName || (user.email ? user.email.split('@')[0] : 'Player'), email: user.email, photo: user.photoURL } : null;
            if (window.app && window.app.onAuthChanged) {
                window.app.onAuthChanged(window.fb.user);
            }
        });
    </script>
