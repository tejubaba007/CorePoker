<body>
    <div id="root">
        <!-- LOGIN -->
        <div id="screen-login" class="screen active" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:28px;">
            <div style="font-size:56px;margin-bottom:4px;">🃏</div>
            <h1 style="font-size:30px;font-weight:800;margin-bottom:6px;">CorePoker</h1>
            <p id="login-subtitle" style="color:#9CA3AF;margin-bottom:28px;text-align:center;max-width:300px;">Log in to track your games and standings.</p>

            <div style="width:100%;max-width:320px;">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" id="login-email" type="email" placeholder="you@email.com" autocomplete="email">
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input class="form-input" id="login-password" type="password" placeholder="At least 6 characters" autocomplete="current-password">
                </div>

                <button class="btn btn-primary btn-lg" id="login-primary-btn" onclick="app.doEmailAuth()" style="margin-top:4px;">Log In</button>

                <div style="text-align:center;margin:12px 0;color:#6B7280;font-size:13px;">
                    <span id="login-toggle-text">New here? </span>
                    <a onclick="app.toggleAuthMode()" style="color:#10B981;font-weight:600;cursor:pointer;text-decoration:underline;" id="login-toggle-link">Create an account</a>
                </div>

                <div style="text-align:center;margin-bottom:12px;">
                    <a onclick="app.doPasswordReset()" style="color:#6B7280;font-size:12px;cursor:pointer;">Forgot password?</a>
                </div>

                <div style="display:flex;align-items:center;gap:10px;margin:18px 0;color:#4B5563;font-size:12px;">
                    <div style="flex:1;height:1px;background:#374151;"></div>OR<div style="flex:1;height:1px;background:#374151;"></div>
                </div>

                <button class="btn btn-secondary" id="login-google-btn" onclick="app.doSignIn()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
                    Continue with Google
                </button>

                <p id="login-status" style="color:#EF4444;font-size:13px;margin-top:16px;text-align:center;min-height:18px;"></p>
            </div>
        </div>

        <!-- GROUPS (landing) -->
        <div id="screen-groups" class="screen">
            <div class="app-header" style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <h1>CorePoker</h1>
                    <div class="subtitle" id="groups-user">Your poker groups</div>
                </div>
                <button class="btn btn-ghost btn-sm" onclick="app.doSignOut()" style="width:auto;padding:8px 12px;">Sign out</button>
            </div>
            <div style="padding: 16px;">
                <button class="btn btn-primary btn-lg" onclick="app.showAddGroupModal()" style="margin-bottom: 10px;">
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    New Group
                </button>
                <button class="btn btn-secondary" onclick="app.showJoinGroupModal()" style="margin-bottom: 24px;">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
