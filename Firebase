                        <input class="form-input" id="ag-name" placeholder="e.g. Friday Crew, Office Game">
                    </div>
                    <button type="button" class="btn btn-primary" onclick="app.handleAddGroup()">Create Group</button>
                </div>
            </div>
        </div>

        <!-- JOIN GROUP MODAL -->
        <div id="modal-joinGroup" class="modal-overlay hidden">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <div class="modal-title">Join Group</div>
                    <button class="modal-close" onclick="app.hideJoinGroupModal()">✕</button>
                </div>
                <div>
                    <div class="form-group">
                        <label class="form-label">Share Code</label>
                        <input class="form-input" id="jg-code" placeholder="e.g. PIZZA42" style="text-transform:uppercase;">
                    </div>
                    <p style="color:#6B7280;font-size:12px;margin-bottom:16px;">Ask the group owner for their share code. You'll get a read-only copy of their games that updates when they re-share.</p>
                    <button type="button" class="btn btn-primary" onclick="app.handleJoinGroup()">Join</button>
                </div>
            </div>
        </div>

        <!-- SHARE GROUP MODAL -->
        <div id="modal-shareGroup" class="modal-overlay hidden">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <div class="modal-title">Share Group</div>
                    <button class="modal-close" onclick="app.hideShareGroupModal()">✕</button>
                </div>
                <div>
                    <p style="color:#9CA3AF;font-size:14px;margin-bottom:12px;">Give this code to your group so they can view these games:</p>
                    <div id="sg-code" style="font-size:28px;font-weight:800;letter-spacing:2px;text-align:center;background:#1F2937;border-radius:12px;padding:16px;color:#F59E0B;margin-bottom:16px;">—</div>
                    <button type="button" class="btn btn-primary" onclick="app.reshareGroup()" style="margin-bottom:8px;">Publish / Update Shared Copy</button>
                    <p style="color:#6B7280;font-size:12px;text-align:center;">Tap to push the latest games to the shared code.</p>
                </div>
            </div>
        </div>

        <!-- ADD MEMBER MODAL -->
        <div id="modal-addMember" class="modal-overlay hidden">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <div class="modal-title">Add Existing Player</div>
                    <button class="modal-close" onclick="app.hideAddMemberModal()">✕</button>
                </div>
                <div id="am-player-list" style="margin-bottom: 16px;"></div>
                <div id="am-empty" class="empty-state" style="display:none; padding: 20px;">
                    <div class="empty-state-title">No other players available</div>
                    <p style="margin-top: 8px;">Everyone you've created is already in this group. Use "New Player" to add someone new.</p>
                </div>
            </div>
        </div>

        <!-- GAME CHIPS MODAL -->
        <div id="modal-gameChips" class="modal-overlay hidden">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <div>
                        <div class="modal-title" id="gc-title">Game</div>
                        <div style="font-size:12px;color:#6B7280;" id="gc-subtitle">date</div>
                    </div>
                    <button class="modal-close" onclick="app.hideGameChips()">✕</button>
                </div>
                <div id="gc-list" style="margin-bottom: 8px;"></div>
            </div>
        </div>

        <!-- CONFIRM MODAL (works in all browsers/webviews where confirm() is blocked) -->
        <div id="modal-confirm" class="modal-overlay hidden">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <div class="modal-title" id="cf-title">Confirm</div>
                    <button class="modal-close" onclick="app.hideConfirm()">✕</button>
                </div>
                <div id="cf-message" style="color:#D1D5DB;font-size:14px;line-height:1.5;margin-bottom:20px;">Are you sure?</div>
                <div style="display:flex;gap:10px;">
                    <button class="btn btn-secondary" onclick="app.hideConfirm()" style="flex:1;">Cancel</button>
                    <button class="btn btn-primary" id="cf-ok" style="flex:1;">Confirm</button>
                </div>
            </div>
        </div>

        <!-- TOAST -->
        <div id="toast" class="toast hidden"></div>

        <!-- NAV BAR -->
        <nav class="nav-bar">
            <button class="nav-item" id="nav-groups" onclick="app.goToScreen('groups')">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Groups
            </button>
            <button class="nav-item active" id="nav-dashboard" onclick="app.goToScreen('dashboard')">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Games
            </button>
            <button class="nav-item" id="nav-leaderboard" onclick="app.goToScreen('leaderboard')">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V3m0 8l4 4m-4-4l-4 4M8 21V13m0 8l4-4m-4 4l-4-4"/></svg>
                Ranks
            </button>
            <button class="nav-item" id="nav-players" onclick="app.goToScreen('players')">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                Players
            </button>
        </nav>
    </div>

    <script>
        var app = {
            players: [],
            games: [],
            groups: [],
            currentGroup: null,
            leaderboardMode: 'standings', // 'standings' or 'expenses'
            leaderboardPeriod: 'all', // 'day','week','month','year','all'
            leaderboardAnchor: null, // anchor date for the selected period
            currentGame: null,
            selectedPlayers: [],
            expenses: [],

            init() {
                document.getElementById('cg-date').value = new Date().toISOString().split('T')[0];
                document.getElementById('cg-buyin').addEventListener('input', () => this.updateChipPreview());
                document.getElementById('cg-chipcount').addEventListener('input', () => this.updateChipPreview());
                this.updateChipPreview();
                // Wait for Firebase auth state. If it doesn't load in 4s, show login anyway.
                this.goToScreen('login');
                document.getElementById('login-status').textContent = 'Loading…';
                setTimeout(() => {
                    if (!window.fb || !window.fb.ready) {
                        document.getElementById('login-status').textContent = '';
                    }
                }, 4000);
            },

            // Called by Firebase when sign-in state changes
            async onAuthChanged(user) {
                if (user) {
                    this.user = user;
                    document.getElementById('login-status').textContent = '';
                    const nameEl = document.getElementById('groups-user');
                    if (nameEl) nameEl.textContent = user.name ? ('Signed in as ' + user.name) : 'Your poker groups';
                    // Load this user's data (cloud first, fall back to local)
                    await this.loadDataForUser(user.uid);
                    this.renderGroups();
                    this.goToScreen('groups');
                } else {
                    this.user = null;
                    this.players = []; this.games = []; this.groups = []; this.expenses = [];
                    this.goToScreen('login');
                }
            },

            doSignIn() {
                if (!window.fb) {
                    this.showToast('Still loading — try again in a moment', 'error');
                    return;
                }
                document.getElementById('login-status').textContent = 'Opening Google sign-in…';
                window.fb.signIn().catch((err) => {
                    document.getElementById('login-status').textContent = 'Google sign-in failed. Try email instead.';
                    console.error('Sign-in error:', err);
                });
            },

            // 'login' or 'signup'
            authMode: 'login',
            toggleAuthMode() {
                this.authMode = this.authMode === 'login' ? 'signup' : 'login';
                const isSignup = this.authMode === 'signup';
                document.getElementById('login-primary-btn').textContent = isSignup ? 'Create Account' : 'Log In';
                document.getElementById('login-subtitle').textContent = isSignup ? 'Create an account to start tracking.' : 'Log in to track your games and standings.';
                document.getElementById('login-toggle-text').textContent = isSignup ? 'Already have an account? ' : 'New here? ';
                document.getElementById('login-toggle-link').textContent = isSignup ? 'Log in' : 'Create an account';
                document.getElementById('login-password').setAttribute('autocomplete', isSignup ? 'new-password' : 'current-password');
                document.getElementById('login-status').textContent = '';
            },

            doEmailAuth() {
                if (!window.fb) { this.showToast('Still loading — try again', 'error'); return; }
                const email = document.getElementById('login-email').value.trim();
                const password = document.getElementById('login-password').value;
                const statusEl = document.getElementById('login-status');

                if (!email || email.indexOf('@') === -1) { statusEl.textContent = 'Enter a valid email.'; return; }
                if (!password || password.length < 6) { statusEl.textContent = 'Password must be at least 6 characters.'; return; }

                statusEl.textContent = this.authMode === 'signup' ? 'Creating account…' : 'Logging in…';
                const action = this.authMode === 'signup'
                    ? window.fb.signUpEmail(email, password)
                    : window.fb.signInEmail(email, password);

                action.catch((err) => {
                    statusEl.textContent = this._authErrorMessage(err);
                    console.error('Email auth error:', err);
                });
            },

            doPasswordReset() {
                if (!window.fb) { this.showToast('Still loading', 'error'); return; }
                const email = document.getElementById('login-email').value.trim();
                const statusEl = document.getElementById('login-status');
                if (!email || email.indexOf('@') === -1) { statusEl.textContent = 'Enter your email above first, then tap reset.'; return; }
                window.fb.resetPassword(email)
                    .then(() => { statusEl.style.color = '#10B981'; statusEl.textContent = 'Reset link sent — check your email.'; setTimeout(()=>{statusEl.style.color='#EF4444';}, 4000); })
                    .catch((err) => { statusEl.textContent = this._authErrorMessage(err); });
            },

            _authErrorMessage(err) {
                const code = err && err.code ? err.code : '';
                if (code === 'auth/email-already-in-use') return 'That email is already registered — try logging in.';
                if (code === 'auth/invalid-email') return 'That email address looks invalid.';
                if (code === 'auth/weak-password') return 'Password too weak — use at least 6 characters.';
                if (code === 'auth/wrong-password' || code === 'auth/invalid-credential') return 'Wrong email or password.';
                if (code === 'auth/user-not-found') return 'No account with that email — create one.';
                if (code === 'auth/too-many-requests') return 'Too many attempts. Wait a moment and retry.';
                if (code === 'auth/network-request-failed') return 'Network error — check your connection.';
                return 'Something went wrong. Please try again.';
            },

            doSignOut() {
                this.showConfirm('Sign Out', 'Sign out of CorePoker?', () => {
                    if (window.fb) window.fb.signOut();
                });
            },

            _userKey() {
                return this.user ? ('corePokerData_' + this.user.uid) : 'corePokerData';
            },

            async loadDataForUser(uid) {
                // Try cloud first
                let data = null;
                try {
                    if (window.fb) data = await window.fb.loadUserData(uid);
                } catch(e) { /* offline — fall back to local */ }

                // Fall back to local copy for this user
                if (!data) {
                    const store = this._getStore();
                    if (store) {
                        try {
                            const saved = store.getItem(this._userKey());
                            if (saved) data = JSON.parse(saved);
                        } catch(e) {}
                    }
                }

                this.players = (data && Array.isArray(data.players)) ? data.players : [];
                this.games = (data && Array.isArray(data.games)) ? data.games : [];
                this.groups = (data && Array.isArray(data.groups)) ? data.groups : [];
                this.expenses = this.games.flatMap(g => (Array.isArray(g.expenses) ? g.expenses : []));
            },

            loadData() {
                // Legacy/local-only load (used before auth). Kept for safety.
                const store = this._getStore();
                if (!store) return;
                let saved = null;
                try { saved = store.getItem(this._userKey()); } catch(e) { return; }
                if (!saved) return;
                let data;
                try { data = JSON.parse(saved); } catch(e) { this._loadError = true; return; }
                this.players = Array.isArray(data.players) ? data.players : [];
                this.games = Array.isArray(data.games) ? data.games : [];
                this.groups = Array.isArray(data.groups) ? data.groups : [];
                this.expenses = this.games.flatMap(g => (Array.isArray(g.expenses) ? g.expenses : []));
            },

            _getStore() {
                try {
                    const t = '__cpg_test__';
                    localStorage.setItem(t, '1');
                    localStorage.removeItem(t);
                    return localStorage;
                } catch(e) {}
                try {
                    const t = '__cpg_test__';
                    sessionStorage.setItem(t, '1');
                    sessionStorage.removeItem(t);
                    return sessionStorage;
                } catch(e) {}
                return null;
            },

            saveData() {
                const payload = {
                    players: this.players,
                    games: this.games,
                    groups: this.groups
                };
                // Local copy (fast, offline) — keyed per user
                try {
                    const store = this._getStore();
                    if (store) store.setItem(this._userKey(), JSON.stringify(payload));
                } catch(e) {}
                // Cloud copy (synced) — fire and forget
                if (this.user && window.fb) {
                    window.fb.saveUserData(this.user.uid, payload).catch(() => {});
                }
            },

            generateId() {
                return Date.now().toString(36) + Math.random().toString(36).substring(2) + Math.random().toString(36).substring(2);
            },

            formatCurrency(amount) {
                return new Intl.NumberFormat('en-IE', { style: 'currency', currency: 'EUR' }).format(amount);
            },

            formatNumber(num) {
                return new Intl.NumberFormat('en-IE').format(num);
            },

            // Escape user-entered text before inserting into innerHTML (prevents XSS)
            esc(str) {
                if (str === null || str === undefined) return '';
                return String(str)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            },

            showToast(message, type) {
                const toast = document.getElementById('toast');
                toast.textContent = message;
                toast.className = 'toast ' + (type || 'success');
                toast.classList.remove('hidden');
                setTimeout(() => toast.classList.add('hidden'), 3000);
            },

            goToScreen(screenName) {
                // Must be signed in for everything except the login screen
                if (screenName !== 'login' && !this.user) {
                    screenName = 'login';
                }
                // Screens that require an open group. Without one, only 'groups' is reachable.
                const groupScopedScreens = ['dashboard', 'players', 'leaderboard', 'createGame', 'selectPlayers', 'gameManagement', 'cashout', 'chipBalance', 'settlement', 'gameSummary'];
                if (!this.currentGroup && groupScopedScreens.indexOf(screenName) !== -1) {
                    this.showToast('Open or create a group first', 'error');
                    screenName = 'groups';
                }

                document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

                // Hide the bottom nav on login, and until a group is open
                const navBar = document.querySelector('.nav-bar');
                if (navBar) navBar.style.display = (this.user && this.currentGroup) ? 'flex' : 'none';

                const screen = document.getElementById('screen-' + screenName);
                if (screen) {
                    screen.classList.add('active');
                    screen.classList.add('fade-in');
                }

                if (screenName === 'groups') {
                    document.getElementById('nav-groups').classList.add('active');
                    this.renderGroups();
                } else if (screenName === 'dashboard') {
                    document.getElementById('nav-dashboard').classList.add('active');
                    this.renderDashboard();
                } else if (screenName === 'players') {
                    document.getElementById('nav-players').classList.add('active');
                    this.renderPlayersList();
                } else if (screenName === 'leaderboard') {
                    document.getElementById('nav-leaderboard').classList.add('active');
                    this.renderLeaderboard();
                } else if (screenName === 'createGame') {
                    document.getElementById('cg-name').value = '';
                    document.getElementById('cg-addon-amount').value = '';
                    document.getElementById('cg-addon-chips').value = '';
                    document.getElementById('cg-notes').value = '';
                    document.getElementById('cg-date').value = new Date().toISOString().split('T')[0];
                    this.updateChipPreview();
                } else if (screenName === 'selectPlayers') {
                    this.renderSelectPlayers();
                } else if (screenName === 'gameManagement') {
                    this.renderGameManagement();
                } else if (screenName === 'cashout') {
                    this.renderCashout();
                }
            },

            // =====================
            // GROUPS
            // =====================
            renderGroups() {
                const container = document.getElementById('groups-list');
                const emptyState = document.getElementById('groups-empty');
                if (!container) return;

                if (this.groups.length === 0) {
                    container.innerHTML = '';
                    if (emptyState) emptyState.style.display = 'block';
                    return;
                }
                if (emptyState) emptyState.style.display = 'none';

                container.innerHTML = this.groups.map(grp => {
                    const groupGames = this.games.filter(g => g.groupId === grp.id);
                    const memberCount = (grp.memberIds || []).length;
                    const badge = grp.joined ? ' <span style="font-size:11px;color:#3B82F6;">shared</span>' : '';
                    const actionBtn = grp.joined
                        ? '<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();app.refreshSharedGroup(\'' + grp.shareCode + '\')" style="width:auto;padding:6px 10px;">↻ Refresh</button>'
                        : '<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();app.showShareGroupModal(\'' + grp.id + '\')" style="width:auto;padding:6px 10px;color:#F59E0B;">Share</button>';
                    return '<div class="game-list-item" style="display:flex;align-items:center;justify-content:space-between;" onclick="app.openGroup(\'' + grp.id + '\')">' +
                        '<div><div class="game-list-name">' + this.esc(grp.name) + badge + '</div>' +
                        '<div class="game-list-meta">' +
                        '<span>' + memberCount + ' players</span>' +
                        '<span>' + groupGames.length + ' games</span>' +
                        '</div></div>' +
                        actionBtn +
                        '</div>';
                }).join('');
            },

            refreshSharedGroup(code) {
                if (!window.fb) { this.showToast('Still loading', 'error'); return; }
                window.fb.fetchGroupByCode(code).then((payload) => {
                    if (!payload) { this.showToast('Shared group not found', 'error'); return; }
                    this._importSharedGroup(code, payload);
                }).catch(() => this.showToast('Refresh failed', 'error'));
            },

            showAddGroupModal() {
                document.getElementById('modal-addGroup').classList.remove('hidden');
                document.getElementById('ag-name').value = '';
                document.getElementById('ag-name').focus();
            },

            hideAddGroupModal() {
                document.getElementById('modal-addGroup').classList.add('hidden');
            },

            handleAddGroup() {
                const name = document.getElementById('ag-name').value.trim();
                if (!name) {
                    this.showToast('Enter a group name', 'error');
                    return;
                }
                const exists = this.groups.some(g => g.name.toLowerCase() === name.toLowerCase());
                if (exists) {
                    this.showToast('A group named "' + name + '" already exists', 'error');
                    return;
                }
                const group = {
                    id: this.generateId(),
                    name: name,
                    memberIds: [],
                    shareCode: this._makeShareCode(),
                    ownerUid: this.user ? this.user.uid : null,
                    createdAt: new Date().toISOString()
                };
                this.groups.push(group);
                this.saveData();
                this.hideAddGroupModal();
                this.renderGroups();
                this.showToast('Group created!');
            },

            _makeShareCode() {
                // Short, readable, avoids ambiguous chars
                const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
                let code = '';
                for (let i = 0; i < 6; i++) code += chars[Math.floor(Math.random() * chars.length)];
                return code;
            },

            // Share: publish this group + its games to the cloud under its code
            showShareGroupModal(groupId) {
                const grp = this.groups.find(g => g.id === groupId);
                if (!grp) return;
                if (!grp.shareCode) { grp.shareCode = this._makeShareCode(); this.saveData(); }
                this._sharingGroupId = groupId;
                document.getElementById('sg-code').textContent = grp.shareCode;
                document.getElementById('modal-shareGroup').classList.remove('hidden');
            },
            hideShareGroupModal() { document.getElementById('modal-shareGroup').classList.add('hidden'); },

            reshareGroup() {
                const grp = this.groups.find(g => g.id === this._sharingGroupId);
                if (!grp || !window.fb) { this.showToast('Cannot share right now', 'error'); return; }
                // Build a self-contained payload: group, its games, and the players in those games
                const groupGames = this.games.filter(g => g.groupId === grp.id);
                const memberIds = new Set(grp.memberIds || []);
                const players = this.players.filter(p => memberIds.has(p.id));
                const payload = {
                    group: { name: grp.name, shareCode: grp.shareCode, ownerName: this.user ? this.user.name : null },
                    games: groupGames,
                    players: players
                };
                window.fb.publishGroup(grp.shareCode, payload)
                    .then(() => this.showToast('Shared! Code: ' + grp.shareCode))
                    .catch(() => this.showToast('Share failed — check connection', 'error'));
            },

            showJoinGroupModal() {
                document.getElementById('jg-code').value = '';
                document.getElementById('modal-joinGroup').classList.remove('hidden');
                document.getElementById('jg-code').focus();
            },
            hideJoinGroupModal() { document.getElementById('modal-joinGroup').classList.add('hidden'); },

            handleJoinGroup() {
                const code = document.getElementById('jg-code').value.trim().toUpperCase();
                if (!code) { this.showToast('Enter a share code', 'error'); return; }
                if (!window.fb) { this.showToast('Still loading — try again', 'error'); return; }
                window.fb.fetchGroupByCode(code).then((payload) => {
                    if (!payload) { this.showToast('No group found for that code', 'error'); return; }
                    this._importSharedGroup(code, payload);
                }).catch(() => this.showToast('Lookup failed — check connection', 'error'));
            },

            _importSharedGroup(code, payload) {
                // Avoid duplicate import
                const existing = this.groups.find(g => g.shareCode === code && g.joined);
                const groupId = existing ? existing.id : this.generateId();

                // Merge players (by id) from the shared copy into the local pool
                (payload.players || []).forEach(sp => {
                    if (!this.players.some(p => p.id === sp.id)) {
                        this.players.push(sp);
                    }
                });

                // Remove any prior copy of this joined group + its games, then re-add fresh
                this.games = this.games.filter(g => !(g.__sharedCode === code));
                this.groups = this.groups.filter(g => !(g.shareCode === code && g.joined));

                const memberIds = (payload.players || []).map(p => p.id);
                this.groups.push({
                    id: groupId,
                    name: (payload.group && payload.group.name ? payload.group.name : 'Shared group') + ' (shared)',
                    memberIds: memberIds,
                    shareCode: code,
                    joined: true,
                    readOnly: true,
                    ownerName: payload.group ? payload.group.ownerName : null,
                    createdAt: new Date().toISOString()
                });
                (payload.games || []).forEach(g => {
                    const copy = Object.assign({}, g, { groupId: groupId, __sharedCode: code });
                    this.games.push(copy);
                });

                this.saveData();
                this.hideJoinGroupModal();
                this.renderGroups();
                this.showToast('Joined "' + (payload.group ? payload.group.name : code) + '"!');
            },

            openGroup(groupId) {
                this.currentGroup = this.groups.find(g => g.id === groupId);
                if (!this.currentGroup) return;
                this.goToScreen('dashboard');
            },

            deleteGroup(groupId) {
                this.showConfirm('Delete Group', 'Delete this group and all its games? This cannot be undone.', () => {
                    this.games = this.games.filter(g => g.groupId !== groupId);
                    this.groups = this.groups.filter(g => g.id !== groupId);
                    if (this.currentGroup && this.currentGroup.id === groupId) {
                        this.currentGroup = null;
                    }
                    this.saveData();
                    this.renderGroups();
                    this.showToast('Group deleted');
                });
            },

            // Players belonging to the current group, resolved from the global pool
            groupMembers() {
                if (!this.currentGroup) return [];
                const ids = new Set(this.currentGroup.memberIds || []);
                return this.players.filter(p => ids.has(p.id));
            },

            renderDashboard() {
                if (!this.currentGroup) { this.goToScreen('groups'); return; }

                // Header reflects the current group
                const titleEl = document.getElementById('dash-group-name');
                if (titleEl) titleEl.textContent = this.currentGroup.name;

                const groupGames = this.games.filter(g => g.groupId === this.currentGroup.id);
                const activeGames = groupGames.filter(g => !g.settled);
                const settledGames = groupGames.filter(g => g.settled);

                document.getElementById('dash-total-games').textContent = groupGames.length;
                document.getElementById('dash-total-players').textContent = (this.currentGroup.memberIds || []).length;
                document.getElementById('dash-active-players').textContent = activeGames.reduce((sum, g) => sum + (g.players ? g.players.length : 0), 0);

                const activeContainer = document.getElementById('dash-active-games');
                const settledContainer = document.getElementById('dash-settled-games');
                const emptyState = document.getElementById('dash-empty');

                if (groupGames.length === 0) {
                    emptyState.style.display = 'block';
                    activeContainer.innerHTML = '';
                    settledContainer.innerHTML = '';
                    return;
                }

                emptyState.style.display = 'none';

                activeContainer.innerHTML = activeGames.map(g => {
                    return '<div class="game-list-item" onclick="app.loadGame(' + "'" + g.id + "'" + ')">' +
                        '<div class="game-list-name">' + this.esc(g.name) + '</div>' +
                        '<div class="game-list-meta">' +
                        '<span class="game-list-status status-active">Active</span>' +
                        '<span>' + g.date + '</span>' +
                        '<span>' + (g.players ? g.players.length : 0) + ' players</span>' +
                        '<span class="currency">' + this.formatCurrency(g.totalPot || 0) + '</span>' +
                        '</div></div>';
                }).join('');

                settledContainer.innerHTML = settledGames.map(g => {
                    return '<div class="game-list-item" onclick="app.viewGameSummary(' + "'" + g.id + "'" + ')">' +
                        '<div class="game-list-name">' + this.esc(g.name) + '</div>' +
                        '<div class="game-list-meta">' +
                        '<span class="game-list-status status-settled">Settled</span>' +
                        '<span>' + g.date + '</span>' +
                        '<span>' + (g.players ? g.players.length : 0) + ' players</span>' +
                        '</div></div>';
                }).join('');
            },

            setLeaderboardMode(mode) {
                this.leaderboardMode = mode;
                this.renderLeaderboard();
            },

            setLeaderboardPeriod(period) {
                this.leaderboardPeriod = period;
                // Anchor to the most recent game's date when switching to a dated period
                this.leaderboardAnchor = this._mostRecentGameDate();
                this.renderLeaderboard();
            },

            // Date of the most recent settled game in this group (or today)
            _mostRecentGameDate() {
                const games = this.games.filter(g => g.groupId === this.currentGroup.id && g.settled && g.results);
                if (games.length === 0) return new Date();
                let latest = null;
                games.forEach(g => {
                    const d = g.date ? new Date(g.date) : new Date();
                    if (!isNaN(d.getTime()) && (latest === null || d > latest)) latest = d;
                });
                return latest || new Date();
            },

            // Move the anchor forward/back by one period unit
            stepPeriod(direction) {
                if (!this.leaderboardAnchor) this.leaderboardAnchor = this._mostRecentGameDate();
                const d = new Date(this.leaderboardAnchor);
                const p = this.leaderboardPeriod;
                if (p === 'day') d.setDate(d.getDate() + direction);
                else if (p === 'week') d.setDate(d.getDate() + 7 * direction);
                else if (p === 'month') d.setMonth(d.getMonth() + direction);
                else if (p === 'year') d.setFullYear(d.getFullYear() + direction);
                this.leaderboardAnchor = d;
                this.renderLeaderboard();
            },

            // Start/end boundaries of the period containing the anchor date
            _periodBounds(anchor, period) {
                const start = new Date(anchor); start.setHours(0,0,0,0);
                const end = new Date(anchor); end.setHours(23,59,59,999);
                if (period === 'day') {
                    // start/end already the single day
                } else if (period === 'week') {
                    const dow = (start.getDay() + 6) % 7; // Monday = 0
                    start.setDate(start.getDate() - dow);
                    end.setTime(start.getTime());
                    end.setDate(start.getDate() + 6);
                    end.setHours(23,59,59,999);
                } else if (period === 'month') {
                    start.setDate(1);
                    end.setMonth(start.getMonth() + 1, 0);
                    end.setHours(23,59,59,999);
                } else if (period === 'year') {
                    start.setMonth(0, 1);
                    end.setMonth(11, 31);
                    end.setHours(23,59,59,999);
                }
                return { start: start, end: end };
            },

            // Human label for the current period
            _periodLabel(anchor, period) {
                const d = new Date(anchor);
                if (period === 'day') {
                    return d.toLocaleDateString('en-IE', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
                } else if (period === 'week') {
                    const b = this._periodBounds(anchor, 'week');
                    const o = { day: 'numeric', month: 'short' };
                    return b.start.toLocaleDateString('en-IE', o) + ' – ' + b.end.toLocaleDateString('en-IE', o) + ', ' + b.end.getFullYear();
                } else if (period === 'month') {
                    return d.toLocaleDateString('en-IE', { month: 'long', year: 'numeric' });
                } else if (period === 'year') {
                    return String(d.getFullYear());
                }
                return 'All time';
            },

            // Does a game's date fall in the anchored period?
            _gameInPeriod(game) {
                if (this.leaderboardPeriod === 'all') return true;
                let d = game.date ? new Date(game.date) : new Date();
                if (isNaN(d.getTime())) d = new Date();
                d.setHours(12,0,0,0);
                const b = this._periodBounds(this.leaderboardAnchor, this.leaderboardPeriod);
                return d >= b.start && d <= b.end;
            },

            renderLeaderboard() {
                if (!this.currentGroup) { this.goToScreen('groups'); return; }
                if (!this.leaderboardPeriod) this.leaderboardPeriod = 'all';
                if (!this.leaderboardMode) this.leaderboardMode = 'standings';
                if (!this.leaderboardAnchor) this.leaderboardAnchor = this._mostRecentGameDate();

                const nameEl = document.getElementById('lb-group-name');
                if (nameEl) nameEl.textContent = this.currentGroup.name;

                // Mode toggle states
                const standBtn = document.getElementById('lb-toggle-standings');
                const expBtn = document.getElementById('lb-toggle-expenses');
                if (standBtn && expBtn) {
                    standBtn.classList.toggle('active', this.leaderboardMode === 'standings');
                    expBtn.classList.toggle('active', this.leaderboardMode === 'expenses');
                }

                // Period type states
                ['day', 'week', 'month', 'year', 'all'].forEach(p => {
                    const el = document.getElementById('lb-period-' + p);
                    if (el) el.classList.toggle('active', this.leaderboardPeriod === p);
                });

                // Date navigator — shown for dated periods, hidden for 'all'
                const nav = document.getElementById('lb-date-nav');
                const label = document.getElementById('lb-date-label');
                if (this.leaderboardPeriod === 'all') {
                    if (nav) nav.style.display = 'none';
                } else {
                    if (nav) nav.style.display = 'flex';
                    if (label) label.textContent = this._periodLabel(this.leaderboardAnchor, this.leaderboardPeriod);
                }

                // Settled games in this group, within the anchored period
                const settledGames = this.games.filter(g =>
                    g.groupId === this.currentGroup.id &&
                    g.settled && g.results &&
                    this._gameInPeriod(g)
                );

                const container = document.getElementById('leaderboard-list');
                const emptyState = document.getElementById('leaderboard-empty');

                if (settledGames.length === 0) {
                    container.innerHTML = '';
                    if (emptyState) {
                        emptyState.style.display = 'block';
                        const titleEl = emptyState.querySelector('.empty-state-title');
                        const pEl = emptyState.querySelector('p');
                        if (titleEl) titleEl.textContent = this.leaderboardPeriod === 'all' ? 'No standings yet' : 'No games in this period';
                        if (pEl) pEl.textContent = this.leaderboardPeriod === 'all' ? 'Play and settle a game to build the leaderboard.' : 'Use ◀ ▶ to find a period with games.';
                    }
                    this._renderGamePicker();
                    return;
                }
                if (emptyState) emptyState.style.display = 'none';

                // For 'all', show one combined ranking. For dated periods, list each game separately.
                if (this.leaderboardPeriod === 'all') {
                    if (this.leaderboardMode === 'expenses') {
                        container.innerHTML = this._renderExpenseTotals(settledGames);
                    } else {
                        container.innerHTML = this._renderStandings(settledGames);
                    }
                } else {
                    container.innerHTML = this._renderGamesSeparately(settledGames);
                }

                this._renderGamePicker();
            },

            // List each game in the period separately, with its own ranking
            _renderGamesSeparately(games) {
                const sorted = games.slice().sort((a, b) => (b.date > a.date ? 1 : -1));
                const isExp = this.leaderboardMode === 'expenses';
                return sorted.map(game => {
                    const header = '<div class="section-title" style="margin-top:18px;">' + this.esc(game.name) + ' • ' + this.esc(game.date || '') + '</div>';
                    return header + (isExp ? this._renderExpenseTotals([game]) : this._renderStandings([game]));
                }).join('');
            },

            // Standings: each player's poker-only net (chips P&L), all-time within period
            _renderStandings(games) {
                const stats = {};
                games.forEach(game => {
                    game.results.forEach(r => {
                        if (!stats[r.playerId]) {
                            stats[r.playerId] = { name: r.name, poker: 0, games: 0 };
                        }
                        // Poker-only = pokerProfit (chips P&L), fall back to rawProfit/profit
                        const pk = (r.pokerProfit !== undefined ? r.pokerProfit
                                  : (r.rawProfit !== undefined ? r.rawProfit : r.profit)) || 0;
                        stats[r.playerId].poker += pk;
                        stats[r.playerId].games += 1;
                    });
                });
                let rows = Object.values(stats);
                rows.forEach(r => { r.poker = Math.round(r.poker * 100) / 100; });
                rows.sort((a, b) => b.poker - a.poker);

                return rows.map((r, i) => {
                    const rank = i + 1;
                    const medal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : (rank + '.');
                    const secondary = r.games + (r.games === 1 ? ' game' : ' games');
                    const pokerStr = (r.poker >= 0 ? '+' : '') + this.formatCurrency(r.poker);
                    const pokerColor = r.poker >= 0 ? '#10B981' : '#EF4444';
                    return '<div class="result-row ' + (r.poker < 0 ? 'loss' : 'profit') + '">' +
                        '<div style="display:flex;align-items:center;gap:12px;flex:1;">' +
                        '<div style="font-size:18px;font-weight:800;min-width:32px;text-align:center;">' + medal + '</div>' +
                        '<div><div class="result-name">' + this.esc(r.name) + '</div>' +
                        '<div style="font-size:12px;color:#6B7280;margin-top:2px;">' + secondary + '</div></div>' +
                        '</div>' +
                        '<div class="result-amount" style="color:' + pokerColor + ';">' + pokerStr + '</div>' +
                        '</div>';
                }).join('');
            },

            // Expense totals: how much each player actually spent (their share of consumption)
            _renderExpenseTotals(games) {
                const spend = {};
                games.forEach(game => {
                    (game.expenses || []).forEach(exp => {
                        // Who consumed this expense? Split the cost across them.
                        const consumers = exp.consumers && exp.consumers.length > 0
                            ? exp.consumers
                            : (game.players || []).map(p => p.name);
                        if (consumers.length === 0) return;
                        // Round shares to cents, remainder to first consumer, so totals reconcile
                        const totalCents = Math.round(exp.amount * 100);
                        const baseShareCents = Math.floor(totalCents / consumers.length);
                        let remainderCents = totalCents - baseShareCents * consumers.length;
                        consumers.forEach(name => {
                            let shareCents = baseShareCents;
                            if (remainderCents > 0) { shareCents += 1; remainderCents -= 1; }
                            if (!spend[name]) spend[name] = { name: name, amount: 0, count: 0 };
                            spend[name].amount += shareCents / 100;
                            spend[name].count += 1;
                        });
                    });
                });
                let rows = Object.values(spend);
                if (rows.length === 0) {
                    return '<div class="empty-state" style="padding:24px;"><div class="empty-state-title">No expenses in this period</div><p>Expenses added during games will show here.</p></div>';
                }
                rows.forEach(r => { r.amount = Math.round(r.amount * 100) / 100; });
                rows.sort((a, b) => b.amount - a.amount);
                const grandTotal = Math.round(rows.reduce((s, r) => s + r.amount, 0) * 100) / 100;

                const list = rows.map((r, i) => {
                    const rank = i + 1;
                    const medal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : (rank + '.');
                    const secondary = 'shared in ' + r.count + (r.count === 1 ? ' expense' : ' expenses');
                    return '<div class="result-row profit">' +
                        '<div style="display:flex;align-items:center;gap:12px;">' +
                        '<div style="font-size:18px;font-weight:800;min-width:32px;text-align:center;">' + medal + '</div>' +
                        '<div><div class="result-name">' + this.esc(r.name) + '</div>' +
                        '<div style="font-size:12px;color:#6B7280;margin-top:2px;">' + secondary + '</div></div>' +
                        '</div>' +
                        '<div class="result-amount" style="color:#F59E0B;">' + this.formatCurrency(r.amount) + '</div>' +
                        '</div>';
                }).join('');

                return list +
                    '<div class="result-row" style="border-top:1px solid #374151;margin-top:8px;">' +
                    '<div class="result-name">Total spent</div>' +
                    '<div class="result-amount" style="color:#F59E0B;">' + this.formatCurrency(grandTotal) + '</div>' +
                    '</div>';
            },

            // List of settled games to drill into per-game chip stacks
            _renderGamePicker() {
                const picker = document.getElementById('lb-game-picker');
                if (!picker) return;
                const games = this.games
                    .filter(g => g.groupId === this.currentGroup.id && g.sett
